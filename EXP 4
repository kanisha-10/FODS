import numpy as np

# Input: Sales for four quarters
q1 = float(input("Enter sales for Q1: "))
q2 = float(input("Enter sales for Q2: "))
q3 = float(input("Enter sales for Q3: "))
q4 = float(input("Enter sales for Q4: "))

# Create NumPy array
sales_data = np.array([q1, q2, q3, q4])

# Calculate total sales
total_sales = np.sum(sales_data)

# Calculate percentage increase from Q1 to Q4
percentage_increase = ((q4 - q1) / q1) * 100

# Display results
print("\nTotal Sales for the Year:", total_sales)
print("Percentage Increase from Q1 to Q4: {:.2f}%".format(percentage_increase))
