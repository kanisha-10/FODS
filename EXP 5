import numpy as np

# Fuel efficiency of car models (in mpg)
fuel_efficiency = np.array([20, 25, 22, 30])

# Calculate average fuel efficiency
average = np.mean(fuel_efficiency)

# Calculate percentage improvement between Model 1 and Model 2
percentage_improvement = ((fuel_efficiency[1] - fuel_efficiency[0]) 
                          / fuel_efficiency[0]) * 100

# Display results
print("Fuel Efficiency Data:", fuel_efficiency)
print("Average Fuel Efficiency:", average, "mpg")
print("Percentage Improvement (Model 1 to Model 2): {:.2f}%"
      .format(percentage_improvement))
